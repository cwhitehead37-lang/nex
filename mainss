<script>
// ── DATA ──
const COINS = [
  { sym: 'BTC', name: 'Bitcoin',   color: '#f7931a', bg: 'rgba(247,147,26,0.15)',  price: 67420.00, icon: '₿' },
  { sym: 'ETH', name: 'Ethereum',  color: '#627eea', bg: 'rgba(98,126,234,0.15)',  price: 3580.50,  icon: 'Ξ' },
  { sym: 'SOL', name: 'Solana',    color: '#9945ff', bg: 'rgba(153,69,255,0.15)',  price: 168.75,   icon: '◎' },
  { sym: 'BNB', name: 'BNB',       color: '#f3ba2f', bg: 'rgba(243,186,47,0.15)',  price: 595.30,   icon: 'B' },
  { sym: 'XRP', name: 'Ripple',    color: '#00aae4', bg: 'rgba(0,170,228,0.15)',   price: 0.5824,   icon: 'X' },
  { sym: 'ADA', name: 'Cardano',   color: '#0033ad', bg: 'rgba(0,51,173,0.15)',    price: 0.4512,   icon: 'A' },
];

let cash = 10000;
let activeCoin = 0;
let tradeMode = 'buy';
let holdings = {};
let orderLog = [];
let chartPoints = {};
let baseChanges = {};

COINS.forEach(c => {
  holdings[c.sym] = 0;
  baseChanges[c.sym] = (Math.random() * 10 - 3).toFixed(2) * 1;
  chartPoints[c.sym] = generateChartData(c.price);
});

function generateChartData(basePrice) {
  const pts = [];
  let p = basePrice * (0.92 + Math.random() * 0.06);
  for (let i = 0; i < 60; i++) {
    p += p * (Math.random() * 0.04 - 0.018);
    pts.push(+p.toFixed(6));
  }
  pts.push(basePrice);
  return pts;
}

// ── CLOCK ──
function updateClock() {
  const now = new Date();
  document.getElementById('clock').textContent =
    now.toLocaleTimeString('en-US', { hour12: false });
}
setInterval(updateClock, 1000);
updateClock();

// ── TICKER STRIP ──
function buildTickerStrip() {
  const strip = document.getElementById('tickerStrip');
  strip.innerHTML = '';
  COINS.forEach((c, i) => {
    const chg = baseChanges[c.sym];
    const div = document.createElement('div');
    div.className = 'ticker-item' + (i === activeCoin ? ' active' : '');
    div.onclick = () => { activeCoin = i; refresh(); };
    div.innerHTML = `
      <div class="ticker-name">${c.sym}/USD</div>
      <div class="ticker-price">$${fmt(c.price)}</div>
      <div class="ticker-change ${chg >= 0 ? 'pos' : 'neg'}">${chg >= 0 ? '+' : ''}${chg.toFixed(2)}%</div>
    `;
    strip.appendChild(div);
  });
}

// ── CHART ──
let chartCtx, animFrame;
function drawChart() {
  if (animFrame) cancelAnimationFrame(animFrame);
  const canvas = document.getElementById('priceChart');
  const container = canvas.parentElement;
  canvas.width = container.clientWidth;
  canvas.height = container.clientHeight;
  const ctx = canvas.getContext('2d');
  const coin = COINS[activeCoin];
  const pts = chartPoints[coin.sym];
  const W = canvas.width, H = canvas.height;
  const pad = { t: 10, b: 24, l: 10, r: 10 };
  const dw = W - pad.l - pad.r;
  const dh = H - pad.t - pad.b;
  const min = Math.min(...pts), max = Math.max(...pts);
  const range = max - min || 1;

  const px = (i) => pad.l + (i / (pts.length - 1)) * dw;
  const py = (v) => pad.t + dh - ((v - min) / range) * dh;

  // Grid lines
  ctx.strokeStyle = 'rgba(255,255,255,0.04)';
  ctx.lineWidth = 1;
  for (let i = 0; i <= 4; i++) {
    const y = pad.t + (i / 4) * dh;
    ctx.beginPath(); ctx.moveTo(pad.l, y); ctx.lineTo(W - pad.r, y); ctx.stroke();
  }

  // Area fill
  const gradient = ctx.createLinearGradient(0, pad.t, 0, H - pad.b);
  gradient.addColorStop(0, coin.color + '30');
  gradient.addColorStop(1, coin.color + '00');
  ctx.beginPath();
  ctx.moveTo(px(0), py(pts[0]));
  for (let i = 1; i < pts.length; i++) ctx.lineTo(px(i), py(pts[i]));
  ctx.lineTo(px(pts.length - 1), H - pad.b);
  ctx.lineTo(px(0), H - pad.b);
  ctx.closePath();
  ctx.fillStyle = gradient;
  ctx.fill();

  // Line
  ctx.beginPath();
  ctx.moveTo(px(0), py(pts[0]));
  for (let i = 1; i < pts.length; i++) ctx.lineTo(px(i), py(pts[i]));
  ctx.strokeStyle = coin.color;
  ctx.lineWidth = 2;
  ctx.stroke();

  // End dot
  const lastX = px(pts.length - 1), lastY = py(pts[pts.length - 1]);
  ctx.beginPath();
  ctx.arc(lastX, lastY, 4, 0, Math.PI * 2);
  ctx.fillStyle = coin.color;
  ctx.fill();
  ctx.beginPath();
  ctx.arc(lastX, lastY, 8, 0, Math.PI * 2);
  ctx.fillStyle = coin.color + '30';
  ctx.fill();

  // Y labels
  ctx.fillStyle = 'rgba(90,100,120,0.9)';
  ctx.font = '10px "Share Tech Mono", monospace';
  ctx.textAlign = 'right';
  for (let i = 0; i <= 4; i++) {
    const v = min + (i / 4) * range;
    const y = pad.t + dh - (i / 4) * dh;
    ctx.fillText('$' + fmt(v), W - pad.r - 2, y - 2);
  }
}

// ── PRICE EDITOR ──
function buildPriceEditor() {
  const grid = document.getElementById('priceEditorGrid');
  grid.innerHTML = '';
  COINS.forEach((c, i) => {
    const row = document.createElement('div');
    row.className = 'price-editor-row';
    row.innerHTML = `
      <div class="coin-badge">
        <div class="coin-dot" style="background:${c.color};box-shadow:0 0 6px ${c.color}60;"></div>
        <span class="coin-sym">${c.sym}</span>
      </div>
      <div class="price-input-wrap">
        <span class="prefix">$</span>
        <input class="price-input" id="priceInput_${c.sym}" type="number" value="${c.price}" min="0.00001" step="any"
          onchange="updatePrice('${c.sym}', this.value)">
      </div>
      <div style="display:flex;gap:4px;">
        <button class="btn btn-outline btn-sm" style="padding:5px 8px;" onclick="nudgePrice('${c.sym}',1.05)">▲</button>
        <button class="btn btn-outline btn-sm" style="padding:5px 8px;" onclick="nudgePrice('${c.sym}',0.95)">▼</button>
      </div>
    `;
    grid.appendChild(row);
  });
}

function updatePrice(sym, val) {
  val = parseFloat(val);
  if (isNaN(val) || val <= 0) return;
  const coin = COINS.find(c => c.sym === sym);
  coin.price = val;
  chartPoints[sym] = generateChartData(val);
  refresh();
  showToast(`${sym} price set to $${fmt(val)}`, 'green');
}

function nudgePrice(sym, factor) {
  const coin = COINS.find(c => c.sym === sym);
  coin.price = +(coin.price * factor).toFixed(8);
  document.getElementById(`priceInput_${sym}`).value = coin.price;
  chartPoints[sym] = generateChartData(coin.price);
  refresh();
}

// ── TRADE ──
function setTradeMode(mode) {
  tradeMode = mode;
  document.getElementById('buyTab').classList.toggle('active', mode === 'buy');
  document.getElementById('sellTab').classList.toggle('active', mode === 'sell');
  updateTradeSummary();
  const coin = COINS[activeCoin];
  document.getElementById('executeBtn').textContent = `${mode.toUpperCase()} ${coin.sym}`;
  document.getElementById('executeBtn').className = `execute-btn btn-${mode === 'buy' ? 'green' : 'red'}`;
}

function updateTradeSummary() {
  const coin = COINS[activeCoin];
  const amt = parseFloat(document.getElementById('tradeAmount').value) || 0;
  const total = amt * coin.price;
  const fee = total * 0.001;
  document.getElementById('summaryPrice').textContent = '$' + fmt(coin.price);
  document.getElementById('summaryTotal').textContent = '$' + fmt(total);
  document.getElementById('summaryFee').textContent = '$' + fmt(fee);
  if (tradeMode === 'buy') {
    document.getElementById('summaryAvail').textContent = '$' + fmt(cash);
  } else {
    document.getElementById('summaryAvail').textContent = `${fmtCoin(holdings[coin.sym] || 0)} ${coin.sym}`;
  }
}

function setQuick(pct) {
  const coin = COINS[activeCoin];
  let amount;
  if (tradeMode === 'buy') {
    amount = (cash * pct) / coin.price;
  } else {
    amount = (holdings[coin.sym] || 0) * pct;
  }
  document.getElementById('tradeAmount').value = +amount.toFixed(8);
  updateTradeSummary();
}

function executeTrade() {
  const coin = COINS[activeCoin];
  const amt = parseFloat(document.getElementById('tradeAmount').value);
  if (!amt || amt <= 0) { showToast('Enter a valid amount', 'red'); return; }
  const total = amt * coin.price;
  const fee = total * 0.001;
  const totalWithFee = total + fee;

  if (tradeMode === 'buy') {
    if (totalWithFee > cash) { showToast('Insufficient funds', 'red'); return; }
    cash -= totalWithFee;
    holdings[coin.sym] = (holdings[coin.sym] || 0) + amt;
    logOrder('BUY', coin.sym, amt, coin.price, totalWithFee);
    showToast(`✓ Bought ${fmtCoin(amt)} ${coin.sym} for $${fmt(totalWithFee)}`, 'green');
  } else {
    if ((holdings[coin.sym] || 0) < amt) { showToast(`Insufficient ${coin.sym}`, 'red'); return; }
    cash += (total - fee);
    holdings[coin.sym] -= amt;
    logOrder('SELL', coin.sym, amt, coin.price, total - fee);
    showToast(`✓ Sold ${fmtCoin(amt)} ${coin.sym} for $${fmt(total - fee)}`, 'green');
  }

  document.getElementById('tradeAmount').value = '';
  refresh();
}

function logOrder(side, sym, amt, price, value) {
  orderLog.unshift({ side, sym, amt, price, value, time: new Date().toLocaleTimeString('en-US', { hour12: false }) });
  if (orderLog.length > 20) orderLog.pop();
}

// ── BALANCE ──
function setBalance() {
  const val = parseFloat(document.getElementById('balanceInput').value);
  if (isNaN(val) || val < 0) return;
  cash = val;
  document.getElementById('balanceInput').value = '';
  refresh();
  showToast(`Balance set to $${fmt(val)}`, 'green');
}
function addBalance(amt) {
  cash = Math.max(0, cash + amt);
  refresh();
}

// ── HOLDINGS ──
function buildHoldings() {
  const list = document.getElementById('holdingsList');
  const active = COINS.filter(c => (holdings[c.sym] || 0) > 0);
  if (active.length === 0) {
    list.innerHTML = '<div style="font-family:var(--mono);font-size:11px;color:var(--muted);padding:4px 0;">No holdings yet.</div>';
    return;
  }
  list.innerHTML = '';
  active.forEach(c => {
    const qty = holdings[c.sym];
    const val = qty * c.price;
    const row = document.createElement('div');
    row.className = 'holding-row';
    row.innerHTML = `
      <div class="holding-left">
        <div class="holding-icon" style="background:${c.bg};color:${c.color};">${c.icon}</div>
        <div>
          <div class="holding-name">${c.name}</div>
          <div class="holding-qty">${fmtCoin(qty)} ${c.sym}</div>
        </div>
      </div>
      <div class="holding-right">
        <div class="holding-val">$${fmt(val)}</div>
        <div class="holding-pnl pos">≈ ${fmtCoin(qty)} coins</div>
      </div>
    `;
    list.appendChild(row);
  });
}

// ── ORDER LOG ──
function buildOrderLog() {
  const log = document.getElementById('orderLog');
  if (orderLog.length === 0) {
    log.innerHTML = '<div style="font-family:var(--mono);font-size:11px;color:var(--muted);">No orders yet.</div>';
    return;
  }
  log.innerHTML = '';
  orderLog.forEach(o => {
    const item = document.createElement('div');
    item.className = 'log-item';
    item.innerHTML = `
      <span class="log-side log-${o.side.toLowerCase()}">${o.side}</span>
      <span style="color:var(--muted2);">${o.sym}</span>
      <span style="color:var(--text);">${fmtCoin(o.amt)}</span>
      <span style="color:var(--muted2);">@$${fmt(o.price)}</span>
      <span style="color:var(--muted);font-size:10px;">${o.time}</span>
    `;
    log.appendChild(item);
  });
}

// ── STATS ──
function buildStats() {
  const coin = COINS[activeCoin];
  const pts = chartPoints[coin.sym];
  const high = Math.max(...pts), low = Math.min(...pts);
  const vol = (coin.price * (Math.random() * 1e9 + 5e8)).toFixed(0);
  const cap = (coin.price * (Math.random() * 1e10 + 1e10)).toFixed(0);
  document.getElementById('statsRow').innerHTML = `
    <div class="stat-card">
      <div class="stat-label">24H HIGH</div>
      <div class="stat-val">$${fmt(high)}</div>
    </div>
    <div class="stat-card">
      <div class="stat-label">24H LOW</div>
      <div class="stat-val">$${fmt(low)}</div>
    </div>
    <div class="stat-card">
      <div class="stat-label">VOLUME</div>
      <div class="stat-val">$${shortNum(parseInt(vol))}</div>
    </div>
    <div class="stat-card">
      <div class="stat-label">MKT CAP</div>
      <div class="stat-val">$${shortNum(parseInt(cap))}</div>
    </div>
  `;
}

// ── PORTFOLIO TOTAL ──
function portfolioTotal() {
  let total = cash;
  COINS.forEach(c => { total += (holdings[c.sym] || 0) * c.price; });
  return total;
}

// ── REFRESH ──
function refresh() {
  const coin = COINS[activeCoin];
  const chg = baseChanges[coin.sym];

  // Ticker
  buildTickerStrip();

  // Active coin header
  document.getElementById('activeCoinIcon').style.background = coin.bg;
  document.getElementById('activeCoinIcon').style.color = coin.color;
  document.getElementById('activeCoinIcon').textContent = coin.icon;
  document.getElementById('activeCoinName').textContent = coin.name;
  document.getElementById('activeCoinSym').textContent = `${coin.sym} / USD`;
  document.getElementById('activeCoinPrice').textContent = '$' + fmt(coin.price);
  const changeBadge = document.getElementById('activeCoinChange');
  changeBadge.textContent = `${chg >= 0 ? '+' : ''}${chg.toFixed(2)}%`;
  changeBadge.className = 'price-change-badge';
  changeBadge.style.background = chg >= 0 ? 'rgba(0,232,162,0.12)' : 'rgba(255,68,102,0.12)';
  changeBadge.style.color = chg >= 0 ? 'var(--green)' : 'var(--red)';

  // Cash
  document.getElementById('cashDisplay').textContent = fmt(cash);

  // Portfolio
  document.getElementById('portfolioTotal').textContent = '$' + fmt(portfolioTotal());

  // Chart
  drawChart();

  // Stats
  buildStats();

  // Trade panel
  document.getElementById('tradeSymLabel').textContent = coin.sym;
  document.getElementById('tradeSuffix').textContent = coin.sym;
  document.getElementById('executeBtn').textContent = `${tradeMode.toUpperCase()} ${coin.sym}`;
  document.getElementById('executeBtn').className = `execute-btn btn-${tradeMode === 'buy' ? 'green' : 'red'}`;
  updateTradeSummary();

  // Holdings & Log
  buildHoldings();
  buildOrderLog();
}

// ── TOAST ──
function showToast(msg, type = 'green') {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.className = `toast ${type} show`;
  setTimeout(() => { t.className = `toast ${type}`; }, 3000);
}

// ── UTILS ──
function fmt(n) {
  if (n === undefined || n === null) return '0.00';
  if (n >= 1000) return n.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  if (n >= 1) return n.toFixed(4);
  return n.toFixed(6);
}

function fmtCoin(n) {
  if (n >= 1000) return n.toFixed(4);
  if (n >= 1) return n.toFixed(6);
  return n.toFixed(8);
}

function shortNum(n) {
  if (n >= 1e12) return (n / 1e12).toFixed(2) + 'T';
  if (n >= 1e9) return (n / 1e9).toFixed(2) + 'B';
  if (n >= 1e6) return (n / 1e6).toFixed(2) + 'M';
  return n.toLocaleString();
}

// ── INIT ──
buildPriceEditor();
refresh();
window.addEventListener('resize', drawChart);

// Subtle live price simulation
setInterval(() => {
  COINS.forEach(c => {
    const drift = 1 + (Math.random() * 0.002 - 0.001);
    c.price = +(c.price * drift).toFixed(8);
    const inp = document.getElementById(`priceInput_${c.sym}`);
    if (inp && document.activeElement !== inp) inp.value = c.price;
    chartPoints[c.sym].push(+(c.price).toFixed(8));
    chartPoints[c.sym].shift();
    baseChanges[c.sym] = +(baseChanges[c.sym] + (Math.random() * 0.04 - 0.02)).toFixed(2);
  });
  refresh();
}, 3000);
</script>

