<!DOCTYPE html>

<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>NEXUS — Crypto Trading Terminal</title>
<link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Syne:wght@400;600;700;800&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #080b10;
    --surface: #0d1117;
    --surface2: #111720;
    --border: rgba(255,255,255,0.06);
    --border-bright: rgba(255,255,255,0.12);
    --green: #00e8a2;
    --green-dim: rgba(0,232,162,0.12);
    --red: #ff4466;
    --red-dim: rgba(255,68,102,0.12);
    --blue: #4d9fff;
    --gold: #f5c842;
    --text: #e8edf5;
    --muted: #5a6478;
    --muted2: #8892a4;
    --mono: 'Share Tech Mono', monospace;
    --sans: 'Syne', sans-serif;
  }

- { margin: 0; padding: 0; box-sizing: border-box; }

body {
background: var(–bg);
color: var(–text);
font-family: var(–sans);
min-height: 100vh;
overflow-x: hidden;
}

/* Scanline overlay */
body::before {
content: ‘’;
position: fixed;
inset: 0;
background: repeating-linear-gradient(
0deg,
transparent,
transparent 2px,
rgba(0,0,0,0.03) 2px,
rgba(0,0,0,0.03) 4px
);
pointer-events: none;
z-index: 1000;
}

/* Ambient glow */
body::after {
content: ‘’;
position: fixed;
top: -200px; left: 50%;
transform: translateX(-50%);
width: 800px; height: 400px;
background: radial-gradient(ellipse, rgba(0,232,162,0.04) 0%, transparent 70%);
pointer-events: none;
z-index: 0;
}

/* ── HEADER ── */
header {
display: flex;
align-items: center;
justify-content: space-between;
padding: 18px 32px;
border-bottom: 1px solid var(–border);
background: rgba(8,11,16,0.95);
backdrop-filter: blur(20px);
position: sticky; top: 0; z-index: 100;
}

.logo {
font-family: var(–sans);
font-weight: 800;
font-size: 20px;
letter-spacing: 0.15em;
color: var(–green);
text-shadow: 0 0 20px rgba(0,232,162,0.5);
}

.logo span { color: var(–muted2); font-weight: 400; }

.header-meta {
display: flex;
align-items: center;
gap: 32px;
font-family: var(–mono);
font-size: 11px;
color: var(–muted2);
}

.live-dot {
display: inline-block;
width: 6px; height: 6px;
border-radius: 50%;
background: var(–green);
margin-right: 6px;
box-shadow: 0 0 8px var(–green);
animation: pulse 2s infinite;
}

@keyframes pulse {
0%, 100% { opacity: 1; }
50% { opacity: 0.4; }
}

.portfolio-badge {
background: var(–green-dim);
border: 1px solid rgba(0,232,162,0.25);
border-radius: 6px;
padding: 6px 14px;
font-family: var(–mono);
font-size: 13px;
color: var(–green);
}

/* ── LAYOUT ── */
.main {
display: grid;
grid-template-columns: 1fr 340px;
grid-template-rows: auto 1fr;
gap: 0;
min-height: calc(100vh - 65px);
}

/* ── LEFT PANEL ── */
.left-panel {
border-right: 1px solid var(–border);
display: flex;
flex-direction: column;
}

/* Market ticker strip */
.ticker-strip {
display: flex;
gap: 0;
border-bottom: 1px solid var(–border);
overflow-x: auto;
scrollbar-width: none;
}
.ticker-strip::-webkit-scrollbar { display: none; }

.ticker-item {
padding: 12px 24px;
border-right: 1px solid var(–border);
cursor: pointer;
transition: background 0.2s;
flex-shrink: 0;
min-width: 130px;
}
.ticker-item:hover, .ticker-item.active {
background: var(–surface);
}
.ticker-item.active { border-bottom: 2px solid var(–green); }

.ticker-name {
font-size: 11px;
color: var(–muted2);
font-family: var(–mono);
letter-spacing: 0.08em;
margin-bottom: 4px;
}

.ticker-price {
font-family: var(–mono);
font-size: 15px;
color: var(–text);
font-weight: 700;
}

.ticker-change {
font-family: var(–mono);
font-size: 10px;
margin-top: 2px;
}
.pos { color: var(–green); }
.neg { color: var(–red); }

/* Chart area */
.chart-area {
padding: 24px 32px;
flex: 1;
}

.coin-header {
display: flex;
align-items: center;
justify-content: space-between;
margin-bottom: 24px;
}

.coin-title {
display: flex;
align-items: center;
gap: 14px;
}

.coin-icon {
width: 44px; height: 44px;
border-radius: 50%;
display: flex;
align-items: center;
justify-content: center;
font-size: 20px;
font-weight: 800;
font-family: var(–sans);
flex-shrink: 0;
}

.coin-name-block h2 {
font-size: 22px;
font-weight: 700;
letter-spacing: -0.01em;
}
.coin-name-block p {
font-family: var(–mono);
font-size: 12px;
color: var(–muted2);
margin-top: 2px;
}

.price-display {
text-align: right;
}
.price-big {
font-family: var(–mono);
font-size: 28px;
font-weight: 700;
letter-spacing: -0.02em;
}
.price-change-badge {
display: inline-block;
font-family: var(–mono);
font-size: 12px;
padding: 3px 8px;
border-radius: 4px;
margin-top: 4px;
}

/* Fake chart */
.chart-container {
position: relative;
height: 220px;
margin-bottom: 24px;
}

canvas#priceChart {
width: 100% !important;
height: 100% !important;
}

/* Stats row */
.stats-row {
display: grid;
grid-template-columns: repeat(4, 1fr);
gap: 16px;
margin-bottom: 24px;
}

.stat-card {
background: var(–surface);
border: 1px solid var(–border);
border-radius: 10px;
padding: 14px 16px;
}
.stat-label {
font-size: 10px;
color: var(–muted);
font-family: var(–mono);
letter-spacing: 0.08em;
text-transform: uppercase;
margin-bottom: 6px;
}
.stat-val {
font-family: var(–mono);
font-size: 14px;
color: var(–text);
font-weight: 700;
}

/* ── RIGHT PANEL ── */
.right-panel {
display: flex;
flex-direction: column;
background: var(–surface);
}

.panel-section {
padding: 20px 24px;
border-bottom: 1px solid var(–border);
}

.section-title {
font-size: 10px;
font-family: var(–mono);
color: var(–muted);
letter-spacing: 0.12em;
text-transform: uppercase;
margin-bottom: 16px;
}

/* Balance editor */
.balance-display {
font-family: var(–mono);
font-size: 26px;
color: var(–text);
margin-bottom: 12px;
font-weight: 700;
}

.balance-display span {
font-size: 14px;
color: var(–muted2);
margin-right: 4px;
}

.input-row {
display: flex;
gap: 8px;
margin-bottom: 10px;
align-items: center;
}

.nexus-input {
background: var(–bg);
border: 1px solid var(–border-bright);
border-radius: 8px;
color: var(–text);
font-family: var(–mono);
font-size: 13px;
padding: 9px 12px;
flex: 1;
outline: none;
transition: border-color 0.2s;
}
.nexus-input:focus {
border-color: var(–green);
box-shadow: 0 0 0 3px rgba(0,232,162,0.08);
}

.btn {
padding: 9px 16px;
border-radius: 8px;
font-family: var(–sans);
font-size: 12px;
font-weight: 700;
letter-spacing: 0.06em;
border: none;
cursor: pointer;
transition: all 0.15s;
}
.btn-green {
background: var(–green);
color: #080b10;
}
.btn-green:hover {
background: #00ffb3;
transform: translateY(-1px);
box-shadow: 0 4px 20px rgba(0,232,162,0.3);
}
.btn-red {
background: var(–red);
color: #fff;
}
.btn-red:hover {
background: #ff6688;
transform: translateY(-1px);
box-shadow: 0 4px 20px rgba(255,68,102,0.3);
}
.btn-outline {
background: transparent;
border: 1px solid var(–border-bright);
color: var(–muted2);
}
.btn-outline:hover {
border-color: var(–green);
color: var(–green);
}
.btn-sm {
padding: 6px 12px;
font-size: 11px;
}

/* Price editor */
.price-editor-grid {
display: flex;
flex-direction: column;
gap: 10px;
}

.price-editor-row {
display: flex;
align-items: center;
gap: 10px;
}

.coin-badge {
display: flex;
align-items: center;
gap: 8px;
width: 90px;
flex-shrink: 0;
}

.coin-dot {
width: 8px; height: 8px;
border-radius: 50%;
flex-shrink: 0;
}

.coin-sym {
font-family: var(–mono);
font-size: 11px;
color: var(–muted2);
font-weight: 700;
letter-spacing: 0.05em;
}

.price-input-wrap {
position: relative;
flex: 1;
}
.price-input-wrap .prefix {
position: absolute;
left: 10px;
top: 50%;
transform: translateY(-50%);
font-family: var(–mono);
font-size: 12px;
color: var(–muted);
}

.price-input {
background: var(–bg);
border: 1px solid var(–border);
border-radius: 7px;
color: var(–text);
font-family: var(–mono);
font-size: 12px;
padding: 7px 10px 7px 22px;
width: 100%;
outline: none;
transition: border-color 0.2s;
}
.price-input:focus {
border-color: rgba(77,159,255,0.5);
}

/* Trade form */
.trade-tabs {
display: flex;
gap: 0;
margin-bottom: 16px;
background: var(–bg);
border-radius: 8px;
padding: 3px;
}
.trade-tab {
flex: 1;
padding: 8px;
text-align: center;
font-size: 12px;
font-weight: 700;
font-family: var(–sans);
letter-spacing: 0.06em;
cursor: pointer;
border-radius: 6px;
transition: all 0.15s;
color: var(–muted2);
border: none;
background: none;
}
.trade-tab.buy.active {
background: var(–green-dim);
color: var(–green);
border: 1px solid rgba(0,232,162,0.2);
}
.trade-tab.sell.active {
background: var(–red-dim);
color: var(–red);
border: 1px solid rgba(255,68,102,0.2);
}

.trade-label {
font-size: 11px;
color: var(–muted);
font-family: var(–mono);
margin-bottom: 6px;
}

.amount-input-wrap {
position: relative;
margin-bottom: 14px;
}
.amount-input-wrap .suffix {
position: absolute;
right: 12px;
top: 50%;
transform: translateY(-50%);
font-family: var(–mono);
font-size: 11px;
color: var(–muted);
}

.quick-btns {
display: flex;
gap: 6px;
margin-bottom: 14px;
}
.quick-btn {
flex: 1;
padding: 5px;
text-align: center;
font-size: 10px;
font-family: var(–mono);
cursor: pointer;
border-radius: 5px;
border: 1px solid var(–border);
background: var(–bg);
color: var(–muted2);
transition: all 0.15s;
}
.quick-btn:hover {
border-color: var(–green);
color: var(–green);
}

.trade-summary {
background: var(–bg);
border: 1px solid var(–border);
border-radius: 8px;
padding: 12px 14px;
margin-bottom: 14px;
}
.trade-summary-row {
display: flex;
justify-content: space-between;
font-family: var(–mono);
font-size: 11px;
color: var(–muted2);
margin-bottom: 6px;
}
.trade-summary-row:last-child { margin-bottom: 0; }
.trade-summary-row .val {
color: var(–text);
font-weight: 700;
}

.execute-btn {
width: 100%;
padding: 13px;
font-size: 13px;
font-weight: 700;
font-family: var(–sans);
letter-spacing: 0.08em;
border-radius: 10px;
border: none;
cursor: pointer;
transition: all 0.2s;
}

/* Holdings */
.holdings-list {
display: flex;
flex-direction: column;
gap: 10px;
}

.holding-row {
display: flex;
align-items: center;
justify-content: space-between;
padding: 10px 12px;
background: var(–bg);
border: 1px solid var(–border);
border-radius: 8px;
transition: border-color 0.2s;
}
.holding-row:hover { border-color: var(–border-bright); }

.holding-left {
display: flex;
align-items: center;
gap: 10px;
}
.holding-icon {
width: 30px; height: 30px;
border-radius: 50%;
display: flex;
align-items: center;
justify-content: center;
font-size: 13px;
font-weight: 800;
}
.holding-name {
font-size: 13px;
font-weight: 700;
}
.holding-qty {
font-family: var(–mono);
font-size: 10px;
color: var(–muted2);
margin-top: 2px;
}

.holding-right { text-align: right; }
.holding-val {
font-family: var(–mono);
font-size: 13px;
font-weight: 700;
}
.holding-pnl {
font-family: var(–mono);
font-size: 10px;
margin-top: 2px;
}

/* Order history / log */
.log-list {
display: flex;
flex-direction: column;
gap: 8px;
max-height: 180px;
overflow-y: auto;
scrollbar-width: thin;
scrollbar-color: var(–border) transparent;
}

.log-item {
display: flex;
justify-content: space-between;
align-items: center;
padding: 8px 12px;
background: var(–bg);
border-radius: 7px;
font-family: var(–mono);
font-size: 11px;
animation: slideIn 0.3s ease;
border: 1px solid var(–border);
}

@keyframes slideIn {
from { opacity: 0; transform: translateX(10px); }
to { opacity: 1; transform: translateX(0); }
}

.log-side {
padding: 2px 7px;
border-radius: 4px;
font-size: 10px;
font-weight: 700;
font-family: var(–sans);
letter-spacing: 0.05em;
}
.log-buy { background: var(–green-dim); color: var(–green); }
.log-sell { background: var(–red-dim); color: var(–red); }

/* Toast notification */
.toast {
position: fixed;
bottom: 30px;
right: 30px;
background: var(–surface2);
border: 1px solid var(–border-bright);
border-radius: 10px;
padding: 14px 20px;
font-family: var(–mono);
font-size: 12px;
color: var(–text);
z-index: 999;
opacity: 0;
transform: translateY(20px);
transition: all 0.3s;
pointer-events: none;
box-shadow: 0 20px 60px rgba(0,0,0,0.5);
}
.toast.show {
opacity: 1;
transform: translateY(0);
}
.toast.green { border-color: rgba(0,232,162,0.3); }
.toast.red { border-color: rgba(255,68,102,0.3); }

/* Scrollbar */
::-webkit-scrollbar { width: 4px; height: 4px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: var(–border-bright); border-radius: 2px; }

.separator {
height: 1px;
background: var(–border);
margin: 0 -24px;
}

/* Responsive adjustments */
@media (max-width: 900px) {
.main { grid-template-columns: 1fr; }
.right-panel { border-top: 1px solid var(–border); }
.stats-row { grid-template-columns: repeat(2,1fr); }
}
</style>

</head>
